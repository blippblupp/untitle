workspace.Swords.ChildAdded:Connect(function(sword)
	if not enabled then return end
	
	task.wait(0.5)
	local main = sword:FindFirstChild("Main")
	if not main then return end
	
	local gui = main:FindFirstChild("Gui")
	if not gui then return end
	
	local ItemInfo = gui:FindFirstChild("ItemInfo")
	if not ItemInfo then return end
	
	local swordowner = ItemInfo:FindFirstChild("Username")
	if not swordowner or swordowner.Text \~= username then return end

	local selling = ItemInfo:FindFirstChild("Selling")
	if not selling then return end
	
	local distance = (base.SellStation.Main.Position - main.Position).Magnitude
	if distance > maxdistance then return end

	-- Enchant Check
	local enchantsfolder = ItemInfo:FindFirstChild("Enchants")
	if not enchantsfolder then return end

	local e1 = enchantsfolder:FindFirstChild("Enchant1")
	local e2 = enchantsfolder:FindFirstChild("Enchant2")
	local e3 = enchantsfolder:FindFirstChild("Enchant3")

	if not e1 or not e2 or not e3 then return end

	local e1t = string.lower(e1.Text):match("^(%S+)")
	local e2t = string.lower(e2.Text):match("^(%S+)")
	local e3t = string.lower(e3.Text):match("^(%S+)")

	local allenchants = {}
	allenchants[e1t] = 1
	if allenchants[e2t] then allenchants[e2t] += 1 else allenchants[e2t] = 1 end
	if allenchants[e3t] then allenchants[e3t] += 1 else allenchants[e3t] = 1 end

	for _, combo in Combinations do
		local match = true
		for enchant, amount in combo do
			if allenchants[enchant] \~= amount then
				match = false
				break
			end
		end
		if match then
			print("🎯 Combo Ditemukan!")
			SendWebhook(combo)
			
			-- Teleport ke sword
			localPlayer.Character:MoveTo(main.Position + Vector3.new(0,6,0))
			task.wait(1)
			paper.Network.InvokeServer("Teleport In Base", "Sell")
			break
		end
	end
end)

