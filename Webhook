local WEBHOOK_URL = "https://discord.com/api/webhooks/PASTE_WEBHOOK_LO_SINI"  -- GANTI INI!

local function SendWebhook(combo)
    local comboText = ""
    for k, v in pairs(combo) do
        comboText = comboText .. k:upper() .. " x" .. v .. "  "
    end
    
    local data = {
        ["content"] = "@everyone **🎯 COMBO BAGUS DITEMUKAN!**",
        ["embeds"] = {{
            ["title"] = "Sword Factory Sniper",
            ["description"] = "**Combo:** " .. comboText .. "\n**Player:** " .. username,
            ["color"] = 0x00ff00,
        }}
    }
    pcall(function()
        HttpService:PostAsync(WEBHOOK_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
        print("Webhook terkirim!")
    end)
end

